# ==============================

# OLLAMA (AI SERVICE)

# ==============================

OLLAMA_ENABLED=<true_or_false>
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=<phi3_or_other_model>
OLLAMA_TIMEOUT=<30000>

# ==============================

# DATABASE (POSTGRES)

# ==============================

POSTGRES_DB=<your_database_name>
POSTGRES_USER=<your_database_user>
POSTGRES_PASSWORD=<your_strong_password>

# ==============================

# SPRING BOOT CONFIG

# ==============================

SPRING_PROFILES_ACTIVE=<dev_or_prod>
SERVER_PORT=<8080>

# ==============================

# SECURITY (JWT)

# ==============================

JWT_SECRET=<generate_a_long_random_256_bit_secret>
JWT_EXPIRATION=<86400000>  # 1 day in ms

# ==============================

# EMAIL (SMTP - GMAIL EXAMPLE)

# ==============================

MAIL_HOST=<smtp.gmail.com>
MAIL_PORT=<587>
MAIL_USERNAME=<your_email_address>
MAIL_PASSWORD=<your_app_password>
MAIL_PROTOCOL=<smtp>
MAIL_SMTP_AUTH=<true>
MAIL_SMTP_STARTTLS_ENABLE=<true>

# ==============================

# STRIPE PAYMENT

# ==============================

STRIPE_SECRET_KEY=<your_stripe_secret_key>
STRIPE_PUBLIC_KEY=<your_stripe_public_key>
STRIPE_WEBHOOK_SECRET=<your_webhook_secret>

# ==============================

# FRONTEND & CORS

# ==============================

FRONTEND_URL=[http://localhost:3000_or_https://yourdomain.com](http://localhost:3000_or_https://yourdomain.com)
CORS_ORIGINS=http://localhost:3000

# ==============================

# REACT (FRONTEND ENV)

# ==============================

REACT_APP_API_URL=[http://localhost:8080_or_https://api.yourdomain.com](http://localhost:8080_or_https://api.yourdomain.com)

# ==============================

# DOCKER / INTERNAL (OPTIONAL)

# ==============================

DB_HOST=<postgres>
DB_PORT=<5432>
